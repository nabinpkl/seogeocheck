{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seogeo.dev/schemas/audit/report/scoring.schema.json",
  "$defs": {
    "auditScoringExclusionReason": {
      "type": "string",
      "enum": [
        "not_applicable",
        "system_error"
      ]
    },
    "auditScoringSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "confidence",
        "earnedWeight",
        "availableWeight",
        "totalPossibleWeight"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "earnedWeight": {
          "type": "number",
          "minimum": 0
        },
        "availableWeight": {
          "type": "number",
          "minimum": 0
        },
        "totalPossibleWeight": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "auditScoringCategoryBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "confidence",
        "earnedWeight",
        "availableWeight",
        "totalPossibleWeight",
        "categoryWeight"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "earnedWeight": {
          "type": "number",
          "minimum": 0
        },
        "availableWeight": {
          "type": "number",
          "minimum": 0
        },
        "totalPossibleWeight": {
          "type": "number",
          "minimum": 0
        },
        "categoryWeight": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "auditScoringCategories": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reachability",
        "crawlability",
        "indexability",
        "sitewide",
        "contentVisibility",
        "metadata",
        "discovery"
      ],
      "properties": {
        "reachability": {
          "$ref": "#/$defs/auditScoringCategoryBreakdown"
        },
        "crawlability": {
          "$ref": "#/$defs/auditScoringCategoryBreakdown"
        },
        "indexability": {
          "$ref": "#/$defs/auditScoringCategoryBreakdown"
        },
        "sitewide": {
          "$ref": "#/$defs/auditScoringCategoryBreakdown"
        },
        "contentVisibility": {
          "$ref": "#/$defs/auditScoringCategoryBreakdown"
        },
        "metadata": {
          "$ref": "#/$defs/auditScoringCategoryBreakdown"
        },
        "discovery": {
          "$ref": "#/$defs/auditScoringCategoryBreakdown"
        }
      }
    },
    "auditScoringRuleBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ruleId",
        "categoryId",
        "status",
        "ruleWeight",
        "earnedWeight",
        "includedInScore",
        "scoreImpact"
      ],
      "properties": {
        "ruleId": {
          "type": "string",
          "minLength": 1
        },
        "categoryId": {
          "$ref": "./common.schema.json#/$defs/auditCategoryId"
        },
        "status": {
          "$ref": "./common.schema.json#/$defs/checkStatus"
        },
        "severity": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "./common.schema.json#/$defs/severity"
            }
          ]
        },
        "ruleWeight": {
          "type": "number",
          "minimum": 0
        },
        "earnedWeight": {
          "type": "number",
          "minimum": 0
        },
        "includedInScore": {
          "type": "boolean"
        },
        "exclusionReason": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/auditScoringExclusionReason"
            }
          ]
        },
        "scoreImpact": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "auditScoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "model",
        "overall",
        "categories",
        "rules"
      ],
      "properties": {
        "model": {
          "type": "string",
          "const": "weighted_rule_scoring"
        },
        "overall": {
          "$ref": "#/$defs/auditScoringSummary"
        },
        "categories": {
          "$ref": "#/$defs/auditScoringCategories"
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/auditScoringRuleBreakdown"
          }
        }
      }
    }
  }
}
