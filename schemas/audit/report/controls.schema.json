{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://seogeo.dev/schemas/audit/report/controls.schema.json",
  "$defs": {
    "redirectStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url"
      ],
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1
        },
        "statusCode": {
          "$ref": "./common.schema.json#/$defs/nullableInteger"
        },
        "location": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "redirectChain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "totalRedirects",
        "finalUrlChanged",
        "chain"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "totalRedirects": {
          "type": "integer",
          "minimum": 0
        },
        "finalUrlChanged": {
          "type": "boolean"
        },
        "finalUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "chain": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/redirectStep"
          }
        },
        "error": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "robotsTxt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "allowsCrawl": {
          "$ref": "./common.schema.json#/$defs/nullableBoolean"
        },
        "evaluatedUserAgent": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "matchedDirective": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "matchedPattern": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "fetchStatusCode": {
          "$ref": "./common.schema.json#/$defs/nullableInteger"
        },
        "url": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "finalUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "error": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "xRobotsTag": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "blocksIndexing"
      ],
      "properties": {
        "value": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "blocksIndexing": {
          "type": "boolean"
        }
      }
    },
    "linkAnnotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
      "properties": {
        "href": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "rel": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "hreflang": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "media": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "type": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "canonicalCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "status",
        "resolvedUrl"
      ],
      "properties": {
        "href": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "rel": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "hreflang": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "media": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "type": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "surface": {
          "type": "string",
          "enum": [
            "html",
            "http_header"
          ]
        },
        "status": {
          "type": "string"
        },
        "resolvedUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "canonicalControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "candidates",
        "uniqueTargetCount",
        "uniqueTargets",
        "htmlCount",
        "headerCount",
        "invalidCandidates",
        "consistency"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canonicalCandidate"
          }
        },
        "uniqueTargetCount": {
          "type": "integer",
          "minimum": 0
        },
        "uniqueTargets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "htmlCount": {
          "type": "integer",
          "minimum": 0
        },
        "headerCount": {
          "type": "integer",
          "minimum": 0
        },
        "invalidCandidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/canonicalCandidate"
          }
        },
        "resolvedCanonicalUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "consistency": {
          "type": "string"
        }
      }
    },
    "canonicalSelfReferenceControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "expectsSelfReference"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "expectsSelfReference": {
          "type": "boolean"
        },
        "finalUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "resolvedCanonicalUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "urlInspection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "isReachable",
        "isHtmlResponse",
        "metaRobotsTags",
        "googlebotRobotsTags",
        "xRobotsTagHeaders",
        "headerCanonicalLinks",
        "headerAlternateLinks",
        "redirectChain",
        "redirectCount",
        "robotsTxt",
        "reusedCurrentPageInspection"
      ],
      "properties": {
        "inspectedUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "status": {
          "type": "string"
        },
        "finalUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "statusCode": {
          "$ref": "./common.schema.json#/$defs/nullableInteger"
        },
        "contentType": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "isReachable": {
          "type": "boolean"
        },
        "isHtmlResponse": {
          "type": "boolean"
        },
        "metaRobotsTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "googlebotRobotsTags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "xRobotsTag": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "xRobotsTagHeaders": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "headerCanonicalLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/linkAnnotation"
          }
        },
        "headerAlternateLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/linkAnnotation"
          }
        },
        "redirectChain": {
          "$ref": "#/$defs/redirectChain"
        },
        "redirectCount": {
          "type": "integer",
          "minimum": 0
        },
        "robotsTxt": {
          "$ref": "#/$defs/robotsTxt"
        },
        "reusedCurrentPageInspection": {
          "type": "boolean"
        }
      }
    },
    "robotsDirectiveEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "target",
        "rawValue",
        "directives",
        "indexingValues",
        "followingValues",
        "snippetValues",
        "archiveValues",
        "translateValues",
        "maxSnippetValues",
        "maxImagePreviewValues",
        "maxVideoPreviewValues",
        "unsupportedTokens",
        "malformedTokens"
      ],
      "properties": {
        "surface": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "rawValue": {
          "type": "string"
        },
        "directives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "indexingValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "followingValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "snippetValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "archiveValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "translateValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxSnippetValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxImagePreviewValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxVideoPreviewValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unsupportedTokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "malformedTokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "robotsSameTargetConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "field",
        "values"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "robotsTargetedOverride": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "field",
        "generalValue",
        "targetedValue"
      ],
      "properties": {
        "target": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "generalValue": {
          "type": "string"
        },
        "targetedValue": {
          "type": "string"
        }
      }
    },
    "robotsTargetSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entries",
        "indexingValues",
        "followingValues",
        "snippetValues",
        "archiveValues",
        "translateValues",
        "maxSnippetValues",
        "maxImagePreviewValues",
        "maxVideoPreviewValues"
      ],
      "properties": {
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/robotsDirectiveEntry"
          }
        },
        "indexingValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "followingValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "snippetValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "archiveValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "translateValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxSnippetValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxImagePreviewValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "maxVideoPreviewValues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "indexing": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "following": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "snippet": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "archive": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "translate": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "maxSnippet": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "maxImagePreview": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "maxVideoPreview": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "robotsControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "entries",
        "targets",
        "sameTargetConflicts",
        "targetedOverrides",
        "unsupportedTokens",
        "malformedTokens",
        "hasBlockingNoindex",
        "hasNoarchiveDirective",
        "hasNotranslateDirective"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/robotsDirectiveEntry"
          }
        },
        "targets": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/robotsTargetSummary"
          }
        },
        "sameTargetConflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/robotsSameTargetConflict"
          }
        },
        "targetedOverrides": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/robotsTargetedOverride"
          }
        },
        "unsupportedTokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "malformedTokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "effectiveIndexing": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveFollowing": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveSnippet": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveArchive": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveTranslate": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveMaxSnippet": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveMaxImagePreview": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveMaxVideoPreview": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "effectiveTarget": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "hasBlockingNoindex": {
          "type": "boolean"
        },
        "hasNoarchiveDirective": {
          "type": "boolean"
        },
        "hasNotranslateDirective": {
          "type": "boolean"
        }
      }
    },
    "alternateLanguageAnnotation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "surface",
        "status",
        "resolvedUrl"
      ],
      "properties": {
        "href": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "rel": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "hreflang": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "media": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "type": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "surface": {
          "type": "string",
          "enum": [
            "html",
            "http_header"
          ]
        },
        "status": {
          "type": "string"
        },
        "resolvedUrl": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "alternateLanguageConflict": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hreflang",
        "targets"
      ],
      "properties": {
        "hreflang": {
          "type": "string"
        },
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "alternateLanguageControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "annotations",
        "validAnnotations",
        "invalidAnnotations",
        "conflicts",
        "groupedByLanguage"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "annotations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternateLanguageAnnotation"
          }
        },
        "validAnnotations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternateLanguageAnnotation"
          }
        },
        "invalidAnnotations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternateLanguageAnnotation"
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alternateLanguageConflict"
          }
        },
        "groupedByLanguage": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/alternateLanguageAnnotation"
            }
          }
        }
      }
    },
    "linkDiscoveryAffectedLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relTokens"
      ],
      "properties": {
        "href": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "text": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "relTokens": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "linkDiscoveryControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "internalCrawlableLinkCount",
        "internalNofollowCount",
        "blockedByRelCount",
        "affectedLinks"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "internalCrawlableLinkCount": {
          "type": "integer",
          "minimum": 0
        },
        "internalNofollowCount": {
          "type": "integer",
          "minimum": 0
        },
        "blockedByRelCount": {
          "type": "integer",
          "minimum": 0
        },
        "affectedLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/linkDiscoveryAffectedLink"
          }
        }
      }
    },
    "internalLinkCoverageControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "sameOriginCrawlableLinkCount",
        "minimumRecommendedCount"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "sameOriginCrawlableLinkCount": {
          "type": "integer",
          "minimum": 0
        },
        "minimumRecommendedCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "titleControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "length",
        "minLength",
        "maxLength"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metaDescriptionControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "length",
        "minLength",
        "maxLength"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": 0
        },
        "minLength": {
          "type": "integer",
          "minimum": 0
        },
        "maxLength": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "headingTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fromLevel",
        "toLevel",
        "expectedNextLevel"
      ],
      "properties": {
        "fromLevel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "toLevel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "expectedNextLevel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "headingText": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        }
      }
    },
    "headingControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "h1Count",
        "headingCount",
        "skippedTransitions",
        "hasMultipleH1",
        "hasSkippedLevels"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "h1Count": {
          "type": "integer",
          "minimum": 0
        },
        "headingCount": {
          "type": "integer",
          "minimum": 0
        },
        "skippedTransitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/headingTransition"
          }
        },
        "hasMultipleH1": {
          "type": "boolean"
        },
        "hasSkippedLevels": {
          "type": "boolean"
        }
      }
    },
    "headingRepeat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count"
      ],
      "properties": {
        "text": {
          "$ref": "./common.schema.json#/$defs/nullableString"
        },
        "count": {
          "type": "integer",
          "minimum": 2
        }
      }
    },
    "headingQualityControl": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "emptyHeadingCount",
        "repeatedHeadingCount",
        "firstHeadingNotH1",
        "repeatedHeadings"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "emptyHeadingCount": {
          "type": "integer",
          "minimum": 0
        },
        "repeatedHeadingCount": {
          "type": "integer",
          "minimum": 0
        },
        "firstHeadingNotH1": {
          "type": "boolean"
        },
        "repeatedHeadings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/headingRepeat"
          }
        }
      }
    },
    "missingAltImage": {
      "type": "object",
      "additionalProperties": false,
      "required": [],
