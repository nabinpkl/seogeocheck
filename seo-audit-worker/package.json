{
  "name": "seo-audit-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/worker.js",
    "start:dev": "tsx src/worker.ts",
    "test": "pnpm run build && node --test \"dist/**/*.test.js\"",
    "install:browsers": "playwright install chromium"
  },
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.8.2",
    "@temporalio/common": "^1.11.7",
    "@temporalio/worker": "^1.11.7",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "crawlee": "^3.16.0",
    "playwright": "^1.56.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@confluentinc/kafka-javascript"
    ]
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
