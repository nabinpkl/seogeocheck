TEMPORAL_VERSION=1.30.1
TEMPORAL_ADMINTOOLS_VERSION=1.30.1
TEMPORAL_UI_VERSION=2.34.0
KAFKA_VERSION=4.2.0
KAFKA_UI_VERSION=latest
MAILPIT_VERSION=latest
POSTGRESQL_VERSION=16
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DEFAULT_PORT=5432
AUDIT_REPORT_SIGNING_SECRET=local-dev-signing-secret
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_PROGRESS_TOPIC=seogeo.audit.progress.v1
KAFKA_PROGRESS_DLQ_TOPIC=seogeo.audit.progress.dlq.v1
KAFKA_PROGRESS_GROUP_ID=seogeo-audit-progress-projector
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false
SEO_GEO_AUTH_PUBLIC_APP_URL=http://localhost:3000
SEO_GEO_AUTH_BACKEND_BASE_URL=http://localhost:8080
SEO_GEO_AUTH_FROM_EMAIL=no-reply@seogeocheck.local
SEO_GEO_AUTH_VERIFICATION_TOKEN_TTL=30m
SEO_GEO_AUTH_VERIFICATION_SEND_COOLDOWN=60s
SEO_GEO_AUTH_VERIFICATION_MAX_SENDS_PER_HOUR=5
SEO_GEO_AUTH_RESET_TOKEN_TTL=30m
SEO_GEO_AUTH_RESET_SEND_COOLDOWN=60s
SEO_GEO_AUTH_RESET_MAX_SENDS_PER_HOUR=5
SEO_GEO_AUTH_FAILED_LOGIN_WINDOW=15m
SEO_GEO_AUTH_FAILED_LOGIN_MAX_DELAY=30s
SERVER_SERVLET_SESSION_COOKIE_SECURE=false
SEO_GEO_AUTH_OAUTH_ISSUER=http://localhost:8080
SEO_GEO_AUTH_OAUTH_KEY_ID=<set-oauth-key-id>
SEO_GEO_AUTH_OAUTH_PRIVATE_KEY=<set-base64-or-pem-private-key>
SEO_GEO_AUTH_OAUTH_PUBLIC_KEY=<set-base64-or-pem-public-key>
SEO_GEO_AUTH_OAUTH_CLIENTS_0_ID=<set-oauth-client-record-id>
SEO_GEO_AUTH_OAUTH_CLIENTS_0_CLIENT_ID=<set-oauth-client-id>
SEO_GEO_AUTH_OAUTH_CLIENTS_0_CLIENT_NAME=<set-oauth-client-name>
SEO_GEO_AUTH_OAUTH_CLIENTS_0_REDIRECT_URIS_0=https://claude.ai/oauth/callback

# ── OpenRouter (AI Worker) ────────────────────────────────────────────
OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
